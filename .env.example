# 데이터 저장 모드: "csv" (기본, DB 불필요) 또는 "db" (PostgreSQL)
DATA_MODE=csv

# PostgreSQL (DATA_MODE=db 일 때만 필요)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crypto_portfolio
DB_USER=postgres
DB_PASSWORD=your_password_here

# Binance API (무료, 키 없이도 공개 데이터 접근 가능)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Upbit API (무료, 키 없이도 공개 데이터 접근 가능)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# 사용할 거래소 선택: binance 또는 upbit
EXCHANGE=binance

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
